// ================================
// KGV - Prisma Schema (PostgreSQL / Supabase)
// ================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// 공통코드
// ================================
model CommonCode {
  id          String   @id @default(cuid())
  groupCode   String   // 그룹 코드 (USER_ROLE, USER_STATUS, MOVIE_RATING, HALL_TYPE, SEAT_TYPE, SCREENING_STATUS, BOOKING_STATUS, TICKET_TYPE)
  code        String   // 코드 값 (ADULT, STANDARD, CONFIRMED, ...)
  label       String   // 한국어 라벨
  description String?  // 설명
  extraValue  String?  // 추가 값 (가격, 할증료 등 JSON 또는 단순 값)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([groupCode, code])
  @@map("common_codes")
}

// ================================
// 사용자
// ================================
model User {
  id          String   @id @default(cuid())
  loginId     String   @unique               // 로그인 아이디
  email       String   @unique
  name        String?
  nickname    String?  @unique
  phone       String?
  password    String
  image       String?
  role        String   @default("USER")       // CommonCode: USER_ROLE
  userStatus  String   @default("ACTIVE")     // CommonCode: USER_STATUS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
  reviews     Review[]

  @@map("users")
}

// ================================
// 영화
// ================================
model Movie {
  id            String    @id @default(cuid())
  title         String
  titleEn       String?
  synopsis      String?
  director      String?
  cast          String?   // JSON string
  genre         String?   // 콤마 구분
  rating        String    @default("ALL")     // CommonCode: MOVIE_RATING
  runtime       Int?      // 분
  releaseDate   DateTime?
  posterUrl     String?
  backdropUrl   String?
  trailerUrl    String?
  tmdbId        String?   @unique
  isNowShowing  Boolean   @default(false)
  isComingSoon  Boolean   @default(false)
  avgScore      Float     @default(0)
  bookingRate   Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  screenings    Screening[]
  reviews       Review[]

  @@map("movies")
}

// ================================
// 극장 / 상영관
// ================================
model Theater {
  id        String   @id @default(cuid())
  name      String
  region    String   // 서울, 경기, 부산 등
  address   String?
  phone     String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  halls     Hall[]

  @@map("theaters")
}

model Hall {
  id         String   @id @default(cuid())
  theaterId  String
  name       String   // 1관, 2관, IMAX관 등
  hallType   String   @default("STANDARD")   // CommonCode: HALL_TYPE
  totalSeats Int

  theater    Theater     @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  seats      Seat[]
  screenings Screening[]

  @@map("halls")
}

model Seat {
  id       String @id @default(cuid())
  hallId   String
  row      String // A, B, C ...
  number   Int    // 1, 2, 3 ...
  seatType String @default("STANDARD")       // CommonCode: SEAT_TYPE

  hall         Hall          @relation(fields: [hallId], references: [id], onDelete: Cascade)
  bookingSeats BookingSeat[]

  @@unique([hallId, row, number])
  @@map("seats")
}

// ================================
// 상영 일정
// ================================
model Screening {
  id        String   @id @default(cuid())
  movieId   String
  hallId    String
  startTime DateTime
  endTime   DateTime
  status    String   @default("SCHEDULED")   // CommonCode: SCREENING_STATUS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie    Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  hall     Hall      @relation(fields: [hallId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("screenings")
}

// ================================
// 예매
// ================================
model Booking {
  id            String    @id @default(cuid())
  bookingNumber String    @unique @default(cuid())
  userId        String
  screeningId   String
  totalPrice    Int
  status        String    @default("PENDING")    // CommonCode: BOOKING_STATUS
  paymentMethod String?
  paymentId     String?
  bookedAt      DateTime  @default(now())
  cancelledAt   DateTime?
  updatedAt     DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  screening    Screening     @relation(fields: [screeningId], references: [id])
  bookingSeats BookingSeat[]

  @@map("bookings")
}

model BookingSeat {
  id         String @id @default(cuid())
  bookingId  String
  seatId     String
  ticketType String @default("ADULT")           // CommonCode: TICKET_TYPE
  price      Int

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat    Seat    @relation(fields: [seatId], references: [id])

  @@unique([bookingId, seatId])
  @@map("booking_seats")
}

// ================================
// 가격 정책
// ================================
model PricePolicy {
  id          String    @id @default(cuid())
  policyGroup String    // TICKET / HALL / TIME / DAY
  code        String
  label       String
  value       Int       // 가격 또는 할증료 (음수 = 할인)
  description String?
  startAt     DateTime? // null = 항상 적용
  endAt       DateTime? // null = 종료일 없음
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([policyGroup, code])
  @@map("price_policies")
}

// ================================
// 리뷰
// ================================
model Review {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  score     Float    // 0.5 ~ 5.0
  content   String?
  isSpoiler Boolean  @default(false)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("reviews")
}
