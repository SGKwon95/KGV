# ================================
# Database (MySQL)
# ================================
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/kgv_db"

# ================================
# NextAuth.js
# ================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# ================================
# OAuth Providers (선택)
# ================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ================================
# Storage (이미지 업로드 - 선택)
# AWS S3 or Cloudflare R2
# ================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""

# ================================
# TMDB API (영화 정보 - 선택)
# ================================
TMDB_API_KEY=""
TMDB_ACCESS_TOKEN=""

# ================================
# 앱 설정
# ================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="KGV"
